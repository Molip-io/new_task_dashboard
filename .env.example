# Notion internal integration token (https://www.notion.so/my-integrations)
# 통합 생성 후, 노션에서 "몰입" 최상위 페이지 → ⋯ → 연결 → 통합 추가 필요
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx

# Slack bot token (https://api.slack.com/apps)
# 필요 스코프: channels:read, channels:history, users:read
# 비공개 채널이면 groups:read, groups:history 추가 + 채널에 봇 초대
SLACK_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx

# 비공개 GitHub 저장소 활동 수집용 토큰. repo/read 권한이 필요합니다.
# 로컬에서는 값이 없으면 `gh auth token`을 보조 수단으로 사용합니다.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# 쉼표로 구분한 퇴사자 Notion 사용자 ID. 화면·담당자 통계에서 제외됩니다.
IGNORED_NOTION_USER_IDS=user-id-1,user-id-2

# AI 요약 실행기. 기본값은 claude -p이며 GPT 기반 CLI로 교체할 수 있습니다.
AI_COMMAND=claude
AI_ARGS=-p
